{
  "name": "majestic-canon-tools",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "description": "Build and packaging system for the Majestic Canonical Dataset",
  "type": "module",
  "private": true,
  "exports": {
    "./verify": {
      "types": "./src/verify.ts",
      "default": "./src/verify.ts"
    },
    "./build": {
      "types": "./src/build.ts",
      "default": "./src/build.ts"
    },
    "./sign": {
      "types": "./src/sign.ts",
      "default": "./src/sign.ts"
    },
    "./editionIdentity": {
      "types": "./src/editionIdentity.ts",
      "default": "./src/editionIdentity.ts"
    },
    "./movieIdentity": {
      "types": "./src/movieIdentity.ts",
      "default": "./src/movieIdentity.ts"
    },
    "./resolveIdentity": {
      "types": "./src/resolveIdentity.ts",
      "default": "./src/resolveIdentity.ts"
    },
    "./buildCanonPayload": {
      "types": "./src/buildCanonPayload.ts",
      "default": "./src/buildCanonPayload.ts"
    },
    "./validate": {
      "types": "./src/validate.ts",
      "default": "./src/validate.ts"
    },
    "./loadCanon": {
      "types": "./src/loadCanon.ts",
      "default": "./src/loadCanon.ts"
    },
    "./toCanonicalShape": {
      "types": "./src/toCanonicalShape.ts",
      "default": "./src/toCanonicalShape.ts"
    },
    "./canonicalJson": {
      "types": "./src/canonicalJson.ts",
      "default": "./src/canonicalJson.ts"
    }
  },
  "bin": {
    "canon-build": "./scripts/build.ts"
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "sign": "tsx scripts/sign.ts",
    "verify": "tsx scripts/verify.ts",
    "enrich": "tsx scripts/enrich.ts",
    "publish:cdn": "tsx scripts/publish.ts",
    "generate-test-keys": "tsx scripts/generate-test-keys.ts",
    "generate-production-keys": "tsx scripts/generate-test-keys.ts -- out/production-keys --production",
    "validate": "tsx scripts/validate.ts",
    "migrate:edition-region": "tsx scripts/migrate-edition-region-to-discs.ts",
    "migrate:hash-filenames": "tsx scripts/migrate-editions-to-hash-filenames.ts",
    "generate:identity-redirects": "tsx scripts/generate-identity-redirects.ts",
    "validate:identity-redirects": "tsx scripts/validateIdentityRedirects.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "gs1:validate": "tsx scripts/gs1-validate.ts",
    "migrate:gs1-schema": "tsx scripts/migrate-gs1-schema.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "dotenv": "^16.4.5",
    "majestic-canon": "file:../majestic-canon"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}